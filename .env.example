# API Configuration
VITE_API_URL=https://jinka-backend.onrender.com/api

# Customer Page URL
VITE_CUSTOMER_PAGE_URL=https://jinka.gov.et

# Environment
VITE_ENV=production

# Cloudinary (unsigned upload for admin hero images)
# Create an unsigned upload preset in Cloudinary and set it below.
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
